# Copy to .env.local for development. Set the same keys in your host (e.g. Vercel)
# Project Settings → Environment Variables.

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Google Gemini — server-only; use an API key from Google AI Studio / Cloud.
# Do NOT use the NEXT_PUBLIC_ prefix for this variable.
GEMINI_API_KEY=
